# IVA — Example environment file
# Copy to `.env` at repo root (same directory as compose.yaml), then edit.
# Some variables are also consumed by the Vite frontend; see the VITE_* section.

# ------------------------------
# Core Postgres credentials
# ------------------------------
# Used by postgis + initdb + iva-job (writer)
PGPASSWORD=change-me-job

# Used by pg_tileserv/pg_featureserv via pgbouncer (read-only app role)
APP_PGPASSWORD=change-me-app
APP_PGUSER=iva_app

# Optional overrides (containers already default correctly)
PGHOST=postgis
PGPORT=5432
PGDATABASE=impacted_values
PGUSER=iva_job

# ------------------------------
# pg_tileserv coordinate system (must match your OpenLayers tile grid)
# ------------------------------
# These are consumed by compose.yaml for pg_tileserv (TS_COORDINATESYSTEM_*).
# Choose an extent in EPSG:3978 that matches your intended map coverage.
# IMPORTANT: Keep these consistent with the VITE_3978_* values below.
IVA_3978_XMIN=-2421618.74911166
IVA_3978_YMIN=-774687.715795296
IVA_3978_XMAX=3062991.079527088
IVA_3978_YMAX=4704011.872167985

# ------------------------------
# FireSTARR acquisition (job)
# ------------------------------
# Container URL (NOT account root). Example from R script:
# https://sawipsprodca.blob.core.windows.net/firestarr
FIRESTARR_BLOB_URL=

# If required, paste a SAS token starting with '?sv=...'. Leave blank if public.
AZURE_SAS_TOKEN=

# Folder discovery mode: 'latest' mimics justTheIntersection.R blob listing; 'template' uses TILE_TEMPLATE+FIRESTARR_GRID.
FIRESTARR_DISCOVERY=latest

# Root prefix under the container to scan for latest runs
FIRESTARR_ROOT_PREFIX=firestarr

# If using template mode, provide these (optional)
FIRESTARR_PREFIX=canada
TILE_TEMPLATE={prefix}/{ymd}/D{horizon}/tile_{ix}_{iy}.tif
# Example grid list: "0,0;0,1;1,0;1,1"
FIRESTARR_GRID=

# Job performance knobs
# Default excludes buildings (millions of polygons) so we rely on aggregates + drill-down later
IVA_EXCLUDE_FEATURE_SETS=buildings
# Number of worker processes for extraction (non-building layers). Start with 1.
IVA_WORKERS=1
IVA_CHUNK_SIZE=250

# Temporary directory used for mosaics
IVA_TMP=/tmp

# Optional evacuation flagging (WFS GeoJSON in EPSG:4326)
EVAC_WFS_URL=

# ------------------------------
# Frontend (Vite) environment
# ------------------------------
# IMPORTANT: Vite only exposes variables prefixed with VITE_*
# You can either:
#  - create app/iva-map/.env with these, OR
#  - configure your dev environment to pass them through.

# pg_tileserv base URL used by the map app
VITE_TILESERV_BASE=http://localhost:7800

# Must match IVA_3978_* above (tile grid alignment)
VITE_3978_XMIN=-2421618.74911166
VITE_3978_YMIN=-774687.715795296
VITE_3978_XMAX=3062991.079527088
VITE_3978_YMAX=4704011.872167985
